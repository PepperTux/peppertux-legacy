(supertux-level
  (version 3)
  (name (_ "Intro"))
  (author "Sophie \"Vaesea\" Ball")
  (license "CC-BY-SA 4.0 International")
  (sector
    (name "main")
    (init-script "Text.set_text(\"Somewhere in a very cold place named Icy Island...\");
Tux.set_bonus(\"grow\");
Letter.set_visible(false);
Nolok.set_action(\"stand-left\");
Tux.deactivate();
Tux.set_dir(true);
Text.set_font(\"normal\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);
wait(1);
Tux.walk(320);")
    (ambient-light
      (color 1 1 1)
    )
    (background
      (x 928)
      (y 704)
      (scroll-speed-x 0)
      (scroll-speed-y 0)
      (speed 0.5)
      (image-top "/images/background/semi_arctic.jpg")
      (image "/images/background/semi_arctic.jpg")
      (image-bottom "/images/background/semi_arctic.jpg")
    )
    (camera
      (name "Camera")
      (mode "normal")
    )
    (decal
      (sprite "/images/engine/menu/logo.png")
      (x 1568)
      (y 512)
    )
    (music
      (file "/music/intro.ogg")
    )
    (particles-snow
    )
    (scriptedobject
      (name "Penny")
      (sprite "/images/creatures/penny/penny.sprite")
      (x 3744)
      (y 896)
    )
    (scriptedobject
      (z-pos -50)
      (physic-enabled #f)
      (solid #f)
      (name "Tree")
      (sprite "/images/tiles/doodads/iceshrub.sprite")
      (x 3904)
      (y 832)
    )
    (scriptedobject
      (z-pos -100)
      (name "Nolok")
      (sprite "/images/creatures/nolok/nolok.sprite")
      (x 3948)
      (y 896)
    )
    (scriptedobject
      (physic-enabled #f)
      (solid #f)
      (name "Fish")
      (sprite "/images/objects/eat-me/eat-me.sprite")
      (x 3648)
      (y 920)
    )
    (scriptedobject
      (physic-enabled #f)
      (solid #f)
      (name "Letter")
      (sprite "/images/objects/letter/letter-small.sprite")
      (x 3968)
      (y 896)
    )
    (scripttrigger
      (oneshot #t)
      (script "Tux.walk(0);
wait(1);
Text.set_text(\"There were two penguins named Tux and Penny.\");
Text.set_font(\"normal\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);
wait(1.5);
Text.set_text(\"They were having a picnic, when suddenly...\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);
wait(1.5);
Nolok.set_action(\"walk-left\");
Nolok.set_velocity(-320, -256);
wait(0.1);
Tux.walk(-140);
Tux.do_jump(-256);
wait(0.2);
Effect.fade_out(0.1);
wait(0.1);
Tux.walk(0);
Penny.set_solid(false);
Penny.set_visible(false);
Nolok.set_solid(false);
Nolok.set_visible(false);
Letter.set_visible(true);
Fish.set_visible(false);
wait(2);
Effect.fade_in(1);
wait(1.5);
Text.set_text(\"Tux and Penny were attacked by Nolok, and Nolok had put a letter on the tree!\");
Text.fade_in(1);
wait(4);
Text.fade_out(1);
wait(1.5);
Tux.walk(320);")
      (button #f)
      (width 32)
      (height 32)
      (x 3616)
      (y 928)
    )
    (scripttrigger
      (oneshot #t)
      (script "Tux.walk(0);
wait(0.5);
Text.set_text(\"When Tux read the letter, he was shocked! He didn't know who this strange Nolok guy was until now!\");
Text.set_font(\"normal\");
Text.fade_in(1);
wait(4);
Text.fade_out(1);
wait(1.5);
Tux.walk(320);
Text.set_text(\"Tux had to find Nolok and save Penny...\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);
wait(1.5);
Effect.fade_out(2);
wait(3);
Level.finish(true);")
      (button #f)
      (width 32)
      (height 128)
      (x 3984)
      (y 928)
    )
    (spawnpoint
      (name "main")
      (x 64)
      (y 896)
    )
    (tilemap
      (solid #f)
      (z-pos -100)
      (width 200)
      (height 35)
      (tiles
