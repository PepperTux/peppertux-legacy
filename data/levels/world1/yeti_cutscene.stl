(supertux-level
  (version 3)
  (name (_ "A Yeti Is Nearby..."))
  (author "Sophie \"Vaesea\" Ball")
  (license "CC-BY-SA 4.0 International")
  (sector
    (name "main")
    (init-script "Yeti.set_action(\"stand-right\");
Tux.deactivate();
Tux.set_dir(true);
Tux.walk(200);
Text.set_text(\"Tux didn't find Penny or Nolok in the castle, so he was sadly walking outside...\");
Text.set_font(\"normal\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);")
    (ambient-light
      (color 1 1 1)
    )
    (background
      (scroll-speed-x 0)
      (scroll-speed-y 0)
      (speed 0.5)
      (image "images/background/arctis2.png")
    )
    (camera
      (name "Camera")
      (mode "normal")
    )
    (music
      (file "/music/voc-dark.music")
    )
    (particles-snow
    )
    (scriptedobject
      (name "Yeti")
      (sprite "/images/creatures/yeti/yeti.sprite")
      (x 1504)
      (y 352)
    )
    (scripttrigger
      (oneshot #t)
      (script "Tux.do_jump(-512);")
      (button #f)
      (width 32)
      (height 32)
      (x 1216)
      (y 896)
    )
    (scripttrigger
      (oneshot #t)
      (script "Yeti.set_action(\"walking-right\");
play_sound(\"sounds/yeti_gna.wav\");
Yeti.set_velocity(350, 0);")
      (button #f)
      (width 32)
      (height 32)
      (x 2400)
      (y 960)
    )
    (scripttrigger
      (oneshot #t)
      (script "Tux.walk(50);
Tux.set_dir(false);
Tux.do_jump(-128);")
      (button #f)
      (width 32)
      (height 32)
      (x 2656)
      (y 960)
    )
    (scripttrigger
      (oneshot #t)
      (script "Tux.walk(320);
Tux.set_dir(true);
Effect.fade_out(2);
wait(3);
Level.finish(true);")
