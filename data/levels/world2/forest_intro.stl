(supertux-level
  (version 3)
  (name (_ "Forest Intro"))
  (author "Sophie \"Vaesea\" Ball")
  (license "CC-BY-SA 4.0 International")
  (sector
    (name "main")
    (init-script "Tux.deactivate();
Effect.sixteen_to_nine(2);
Text.set_font(\"normal\");
Text.set_text(\"Tux had reached a Forest Island.\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);
wait(1.5);
Tux.walk(230);")
    (ambient-light
      (color 1 1 1)
    )
    (background
      (scroll-speed-x 0)
      (scroll-speed-y 0)
      (speed 0.25)
      (image-top "/images/background/BlueRock_Forest/blue-top.jpg")
      (image "/images/background/BlueRock_Forest/blue-middle.jpg")
      (image-bottom "/images/background/BlueRock_Forest/blue-bottom.jpg")
    )
    (camera
      (name "Camera")
      (mode "normal")
    )
    (music
      (file "/music/forestmap.ogg")
    )
    (scriptedobject
      (name "Granito")
      (sprite "/images/creatures/granito/granito.sprite")
      (x 1920)
      (y 512)
    )
    (scripttrigger
      (oneshot #t)
      (script "Granito.set_velocity(-100, 0);
Granito.set_action(\"walk-left\");")
      (button #f)
      (width 32)
      (height 32)
      (x 384)
      (y 832)
    )
    (scripttrigger
      (oneshot #t)
      (script "Tux.walk(0);
wait(4);
Granito.set_velocity(0, 0);
Granito.set_action(\"lookdown-left\");
Text.set_font(\"normal\");
Text.set_text(\"Granito: Welcome to the Forest Island!\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);
wait(1.5);
Text.set_text(\"Unfortunately, a creature named Nolok has turned one of the once interesting ruins here into his home, along with corrupting the area around it...\");
Text.fade_in(1);
wait(5);
Text.fade_out(1);
wait(1.5);
Text.set_text(\"Tux: I can help defeat him! He captured my friend!\");
Text.fade_in(1);
wait(3);
Text.fade_out(1);
wait(1.5);
Text.set_text(\"Granito: You can? That's good. Just be careful, this forest has been turned into a dangerous place...\");
Text.fade_in(1);
wait(4);
Text.fade_out(1);
wait(1.5);
Granito.set_velocity(100, 0);
Granito.set_action(\"walk-right\");
Effect.fade_out(2);
wait(3);
Level.finish(true);")
      (button #f)
      (width 32)
      (height 32)
      (x 928)
      (y 896)
    )
    (spawnpoint
      (name "main")
      (x 320)
      (y 800)
    )
